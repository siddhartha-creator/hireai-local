# Docker Compose PostgreSQL defaults
POSTGRES_DB=hireai_local
POSTGRES_USER=hireai
POSTGRES_PASSWORD=hireai
POSTGRES_PORT=5432
JWT_SECRET_KEY=replace-with-a-local-secret

# Non-Docker local PostgreSQL on Windows
# Use this when PostgreSQL is installed directly on your machine.
# DATABASE_URL takes precedence over the POSTGRES_* values in the backend.
DATABASE_URL=postgresql+psycopg://hireai:root1@localhost:5432/hireai_local
