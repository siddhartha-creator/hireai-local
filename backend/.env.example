PROJECT_NAME=HireAI Local
ENVIRONMENT=local

# Non-Docker local PostgreSQL on Windows.
# This value takes precedence over POSTGRES_HOST/PORT/DB/USER/PASSWORD.
DATABASE_URL=postgresql+psycopg://hireai:root1@localhost:5432/hireai_local

# Docker Compose PostgreSQL defaults.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=hireai_local
POSTGRES_USER=hireai
POSTGRES_PASSWORD=root1
JWT_SECRET_KEY=replace-with-a-local-secret
BACKEND_CORS_ORIGINS=http://localhost:3000
RESUME_UPLOAD_DIR=/app/uploads/resumes
